	<parameter name="d_dari" class="java.lang.String"/>
	<parameter name="d_sampai" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT detail_transaksi_barangmsk.no_urut, 
detail_transaksi_barangmsk.no_fak, 
barang.id_barang as idbarang, 
barang.nama_barang as namabarang, 
barang.harga_beli as hargabeli,
 transaksi_barang_masuk.tgl_brgmsk as tglmasuk, 
barang.stok as stock, 
detail_transaksi_barangmsk.jumlah_brgmsk 
FROM detail_transaksi_barangmsk 
join barang ON barang.id_barang = detail_transaksi_barangmsk.id_barang 
join transaksi_barang_masuk ON transaksi_barang_masuk.no_fak = detail_transaksi_barangmsk.no_fak
WHERE transaksi_barang_masuk.tgl_brgmsk BETWEEN $P{d_dari} AND $P{d_sampai}]]>
	</queryString>
